@model VoetbalAdministratie.Web.Models.Wedstrijd
@using VoetbalAdministratie.Web.Models
@{
    ViewData["Title"] = "Nieuwe wedstrijd";
    var teams = ViewBag.Teams as List<Team> ?? new List<Team>();
    var velden = ViewBag.Velden as List<Veld> ?? new List<Veld>();
    var standaardTijdsloten = new[] { "18:00-19:30", "19:30-21:00" };
    var isAangepastTijdslot = !string.IsNullOrWhiteSpace(Model.Tijdslot) && !standaardTijdsloten.Contains(Model.Tijdslot);
}

<h1 class="h3">Nieuwe wedstrijd</h1>

@if (TempData["Error"] is string err)
{
    <div class="alert alert-danger">@err</div>
}

<form method="post" class="mt-3">
    @Html.AntiForgeryToken()

    <div class="row g-3">
        <div class="col-md-6">
            <label class="form-label">Team</label>
            <select class="form-select" asp-for="TeamId">
                <option value="0">Kies team...</option>
                @foreach (var t in teams)
                {
                    <option value="@t.TeamId">@t.Naam (@t.Categorie)</option>
                }
            </select>
            <span class="text-danger" asp-validation-for="TeamId"></span>
        </div>
        <div class="col-md-6">
            <label class="form-label">Veld</label>
            <select class="form-select" asp-for="VeldId">
                <option value="0">Kies veld...</option>
                @foreach (var v in velden)
                {
                    <option value="@v.VeldId">@v.Naam</option>
                }
            </select>
            <span class="text-danger" asp-validation-for="VeldId"></span>
        </div>
        <div class="col-md-4">
            <label class="form-label">Datum</label>
            <input class="form-control" asp-for="Datum" type="date" />
        </div>
        <div class="col-md-4">
            <label class="form-label">Tijdslot</label>
            <input asp-for="Tijdslot" type="hidden" />
            <select class="form-select" id="tijdslotKeuze">
                <option value="">Kies tijdslot...</option>
                @foreach (var tijdslot in standaardTijdsloten)
                {
                    if (Model.Tijdslot == tijdslot)
                    {
                        <option value="@tijdslot" selected>@tijdslot</option>
                    }
                    else
                    {
                        <option value="@tijdslot">@tijdslot</option>
                    }
                }
                @if (isAangepastTijdslot)
                {
                    <option value="__anders__" selected>Anders, namelijk...</option>
                }
                else
                {
                    <option value="__anders__">Anders, namelijk...</option>
                }
            </select>
            <input
                class="form-control mt-2"
                id="tijdslotAnders"
                placeholder="Bijv. 20:00-21:30"
                value="@(isAangepastTijdslot ? Model.Tijdslot : string.Empty)"
                style="display:@(isAangepastTijdslot ? "block" : "none");" />
            <span class="text-danger" asp-validation-for="Tijdslot"></span>
        </div>
        <div class="col-md-4">
            <label class="form-label">Status</label>
            <select class="form-select" asp-for="Status">
                <option value="Gepland">Gepland</option>
                <option value="Gespeeld">Gespeeld</option>
                <option value="Geannuleerd">Geannuleerd</option>
                <option value="Uitgesteld">Uitgesteld</option>
            </select>
        </div>
        <div class="col-md-12">
            <label class="form-label">Tegenstander (optioneel)</label>
            <input class="form-control" asp-for="Tegenstander" />
        </div>
        <div class="col-md-12">
            <div class="form-text">
                Beschikbaarheid: <strong>strenge check</strong> (alle spelers van het team moeten “Beschikbaar” zijn op datum+tijdslot).
            </div>
        </div>
    </div>

    <div class="mt-4 d-flex gap-2">
        <button class="btn btn-primary" type="submit">Inplannen</button>
        <a class="btn btn-outline-secondary" asp-action="Index">Annuleren</a>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        (function () {
            const keuze = document.getElementById("tijdslotKeuze");
            const andersInput = document.getElementById("tijdslotAnders");
            const tijdslotHidden = document.getElementById("Tijdslot");
            if (!keuze || !andersInput || !tijdslotHidden) return;

            const andersWaarde = "__anders__";

            const syncValue = function () {
                if (keuze.value === andersWaarde) {
                    andersInput.style.display = "block";
                    tijdslotHidden.value = andersInput.value.trim();
                    return;
                }

                andersInput.style.display = "none";
                tijdslotHidden.value = keuze.value;
            };

            keuze.addEventListener("change", syncValue);
            andersInput.addEventListener("input", syncValue);
            syncValue();
        })();
    </script>
}

