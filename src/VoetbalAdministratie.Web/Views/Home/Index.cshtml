@{
    ViewData["Title"] = "Home";
}

<div class="home-hero border rounded-4 p-4 p-md-5 mb-4">
    <div>
        <div class="text-uppercase small text-muted fw-semibold">Prototype</div>
        <h1 class="h2 mb-2">Slimme Voetbalclub Administratie</h1>
        <p class="mb-0 text-muted">
            Korte demo-app voor leden, betalingen en planning.
        </p>
    </div>
</div>

<div class="row g-3">
    <div class="col-md-4">
        <div class="card h-100 shadow-sm">
            <div class="card-body d-flex flex-column">
                <h2 class="h5">Leden</h2>
                <p class="text-muted mb-4">Beheer leden en basisgegevens.</p>
                <a class="btn btn-sm btn-primary mt-auto align-self-start" asp-controller="Leden" asp-action="Index">Openen</a>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card h-100 shadow-sm">
            <div class="card-body d-flex flex-column">
                <h2 class="h5">Betalingen</h2>
                <p class="text-muted mb-4">Overzicht van contributies en betalingen registreren.</p>
                <a class="btn btn-sm btn-primary mt-auto align-self-start" asp-controller="Betalingen" asp-action="Index">Openen</a>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card h-100 shadow-sm">
            <div class="card-body d-flex flex-column">
                <h2 class="h5">Planning</h2>
                <p class="text-muted mb-4">Wedstrijden plannen en beheren.</p>
                <a class="btn btn-sm btn-primary mt-auto align-self-start" asp-controller="Planning" asp-action="Index">Openen</a>
            </div>
        </div>
    </div>
</div>
