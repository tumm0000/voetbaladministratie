@model VoetbalAdministratie.Web.ViewModels.LidTeamKoppelViewModel
@using VoetbalAdministratie.Web.Models
@using VoetbalAdministratie.Web.Repositories
@{
    ViewData["Title"] = "Team koppelen";
    var teams = ViewBag.Teams as List<Team> ?? new List<Team>();
    var lidmaatschappen = ViewBag.Lidmaatschappen as List<LidTeamLidmaatschap> ?? new List<LidTeamLidmaatschap>();
    var lidNaam = ViewBag.LidNaam as string ?? "Lid";
}

<h1 class="h3">Team koppelen</h1>
<p class="text-muted mb-0">Lid: <strong>@lidNaam</strong></p>

@if (TempData["Message"] is string msg)
{
    <div class="alert alert-success mt-3">@msg</div>
}
@if (TempData["Error"] is string err)
{
    <div class="alert alert-danger mt-3">@err</div>
}

<div class="mt-4">
    <h2 class="h5">Teams van dit lid</h2>

    @if (lidmaatschappen.Count == 0)
    {
        <div class="alert alert-info mb-0">Nog geen teamkoppelingen.</div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-striped align-middle">
                <thead>
                <tr>
                    <th>Team</th>
                    <th>Categorie</th>
                    <th>Vanaf</th>
                    <th class="text-end">Actie</th>
                </tr>
                </thead>
                <tbody>
                @foreach (var m in lidmaatschappen)
                {
                    <tr>
                        <td>@m.TeamNaam</td>
                        <td>@m.TeamCategorie</td>
                        <td>@m.VanafDatum.ToString("yyyy-MM-dd")</td>
                        <td class="text-end">
                            <form method="post" asp-action="VerwijderLidTeam" class="m-0 d-inline-flex align-items-center"
                                  onsubmit="return confirm('Weet je zeker dat je dit lid uit dit team wilt halen?');">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="lidTeamId" value="@m.LidTeamId" />
                                <input type="hidden" name="lidId" value="@m.LidId" />
                                <button class="btn btn-sm btn-outline-danger" type="submit">Verwijder</button>
                            </form>
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    }
</div>

<hr class="my-4" />

<h2 class="h5">Nieuwe koppeling</h2>

<form method="post" class="mt-3">
    @Html.AntiForgeryToken()
    <input type="hidden" asp-for="LidId" />

    <div class="row g-3">
        <div class="col-md-8">
            <label class="form-label">Team</label>
            <select class="form-select" asp-for="TeamId">
                <option value="0">Kies team...</option>
                @foreach (var t in teams)
                {
                    <option value="@t.TeamId">@t.Naam (@t.Categorie)</option>
                }
            </select>
            <span class="text-danger" asp-validation-for="TeamId"></span>
        </div>
        <div class="col-md-4">
            <label class="form-label">Vanaf</label>
            <input class="form-control" asp-for="VanafDatum" type="date" />
            <span class="text-danger" asp-validation-for="VanafDatum"></span>
        </div>
        <div class="col-12">
            <div class="form-text">
                Regel: bij teams met categorie <strong>Senioren</strong> moet het lid <strong>18+</strong> zijn op de koppeldatum.
                Bij <strong>Jeugd</strong> (of teams die beginnen met <strong>JO</strong>) moet het lid <strong>jonger dan 18</strong> zijn op de koppeldatum.
            </div>
        </div>
    </div>

    <div class="mt-4 d-flex gap-2">
        <button class="btn btn-primary" type="submit">Koppelen</button>
        <a class="btn btn-outline-secondary" asp-action="Index">Annuleren</a>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
